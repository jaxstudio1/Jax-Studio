# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
build/
.cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
venv/
.venv/

# Environment & secrets — copy .env.example to .env and fill in
**/.env
!**/.env.example

# Uploaded user content (per-deploy, not source-controlled)
backend/uploads/*
!backend/uploads/.gitkeep

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.log

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Emergent-specific (do not commit per-project state)
.emergent/
